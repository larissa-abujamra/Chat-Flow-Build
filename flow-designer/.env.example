# ---------------------------------------------------------------------------
# Onboarding (/api/*) serverless functions — required environment variables.
# Set these in Vercel → Project → Settings → Environment Variables (Production
# AND Preview). Never commit real values; this file documents the names only.
# Locally you can copy to `.env` (gitignored) and run `vercel dev`.
# ---------------------------------------------------------------------------

# OpenRouter — Gemini 2.5 Flash/Pro + Perplexity Sonar Pro.
# Used by: normalize, ocr, places (fallback), cnpj-lookup, tone-from-text,
#          research, catalog, site-scrape, ifood/detect.
OPENROUTER_API_KEY=

# Google Places API — primary business/address lookup.
# Used by: places.
GOOGLE_PLACES_API_KEY=

# cpfcnpj.com.br — official Receita Federal CNPJ data.
# Used by: cnpj, cnpj-lookup.
CPFCNPJ_TOKEN=
# Package "6" = CNPJ D (full data: address, phones, email). Override only if your
# token has a different package contracted.
CPFCNPJ_PACKAGE=6

# Scrapingdog — web scraping + Instagram profile scraping.
# Used by: instagram, catalog, site-scrape, ifood/detect.
SCRAPINGDOG_API_KEY=

# Apify — iFood menu importer (actor run-sync). Without this, ifood/catalog
# honestly returns { configured: false } and the UI shows "not available".
# Used by: ifood/catalog.
APIFY_API_TOKEN=
# Apify actor id for the iFood menu scraper (default works; override if needed).
IFOOD_APIFY_ACTOR=xmJ7nVZ3VrxjuFpmc
